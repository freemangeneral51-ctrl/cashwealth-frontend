PORT=4000
# For local Docker Mongo
LOCAL_MONGO_URI=mongodb://127.0.0.1:27017/cashwealth
# Leave MONGO_URI empty to use LOCAL_MONGO_URI
MONGO_URI=
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1h
FRONTEND_ORIGIN=http://localhost:3000
# Optional email
SMTP_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Cashwealth <no-reply@yourdomain.com>"
# Optional platform wallets
PLATFORM_USDT_ADDRESS=
PLATFORM_TRX_ADDRESS=
#
# Default admin (set both to auto-provision admin on startup)
# ADMIN_EMAIL=admin@cashwealth.local
# ADMIN_PASSWORD=ChangeMe_Strong123!
# ADMIN_NAME=Administrator
